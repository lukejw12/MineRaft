execute if score @s mr.crop_plot_hits matches 4 run data modify storage mineraft:crop_plot loot set value [{type:"palm_leaf",min:1,max:2},{type:"palm_seed",count:1}]
execute if score @s mr.crop_plot_hits matches 5 run data modify storage mineraft:crop_plot loot set value [{type:"wooden_plank",min:1,max:3},{type:"palm_leaf",min:1,max:2}]